POSTGRES_DB=expense_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DOCKER_SHARED_NETWORK=spendit-net

BACKEND_PORT=8080
BACKEND_LOG_LEVEL=info
# Optional full DSN. Leave empty to use split DB vars below.
BACKEND_DATABASE_URL=
BACKEND_DB_HOST=spendit-postgres
BACKEND_DB_PORT=5432
BACKEND_DB_USER=postgres
BACKEND_DB_PASSWORD=postgres
BACKEND_DB_NAME=expense_tracker
BACKEND_DB_SSLMODE=disable
BACKEND_DB_SCHEMA=spendit
BACKEND_CORS_ALLOW_ORIGIN=http://localhost:3000
BACKEND_JWT_SECRET=change-me-in-production
BACKEND_JWT_TOKEN_EXPIRY_HOURS=168

FRONTEND_PORT=3000
FRONTEND_API_BASE_URL=http://localhost:8080
FRONTEND_VITE_API_BASE_URL=http://localhost:8080
