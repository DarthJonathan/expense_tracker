PORT=8080
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/expense_tracker?sslmode=disable
# Alternative to DATABASE_URL (used when DATABASE_URL is empty):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=expense_tracker
# DB_SSLMODE=disable
# Optional extra URL query params, comma-separated key=value pairs:
# DB_OPTIONS=TimeZone=UTC
DB_SCHEMA=spendit
CORS_ALLOW_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_TOKEN_EXPIRY_HOURS=168
